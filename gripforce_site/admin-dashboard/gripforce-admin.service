Group=mame_m_kane
WorkingDirectory=/home/mame_m_kane/gripforce_site/admin-dashboard/backend
ExecStart=/home/mame_m_kane/gripforce_site/admin-dashboard/backend/venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000
