---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../config.js';

const zones = [
  { name: 'Plateau, Médina, Fann', delay: '24h', price: 'Offerte pour les 15 premières commandes, sinon 1 000 F' },
  { name: 'Almadies, Ngor, Yoff, Mermoz', delay: '24h', price: 'Offerte pour les 15 premières commandes, sinon 1 500 F' },
  { name: 'Parcelles Assainies, Pikine, Thiaroye', delay: '24h', price: 'Offerte pour les 15 premières commandes, sinon 2 000 F' },
  { name: 'Rufisque, Keur Massar, Bargny', delay: '24-48h', price: 'Offerte pour les 15 premières commandes, sinon 2 500 F' },
  { name: 'Autres villes (Thiès, Saint-Louis, Mbour, etc.)', delay: '3-5 jours', price: 'Sur devis, via transporteur' },
];
---

<BaseLayout title={`Livraison · ${SITE.name}`} description="Modalités de livraison GripForce">
  <section class="container-edge py-16 md:py-24">
    <div class="max-w-4xl">
      <div class="label-eyebrow mb-4">Livraison</div>
      <h1 class="h-display text-display-lg mb-6">Où et comment on livre.</h1>
      <p class="text-lg text-ink-700 dark:text-ink-200 leading-relaxed mb-12 max-w-2xl">
        Livraison rapide à Dakar et sa banlieue en 24h. Pour les autres villes du Sénégal, on s'organise avec un transporteur.
      </p>

      <div class="space-y-px bg-ink-200 dark:bg-ink-700 border border-ink-200 dark:border-ink-700 rounded-2xl overflow-hidden">
        {zones.map((zone, i) => (
          <div class="bg-ink-50 dark:bg-ink-900 p-6 md:p-8 grid md:grid-cols-12 gap-4 md:gap-6 items-start">
            <div class="md:col-span-1">
              <span class="font-mono text-xs uppercase tracking-[0.2em] text-ink-500 dark:text-ink-400">
                {String(i + 1).padStart(2, '0')}
              </span>
            </div>
            <div class="md:col-span-5">
              <h3 class="font-display text-xl font-medium mb-1">{zone.name}</h3>
              <div class="text-sm text-ink-500 dark:text-ink-400">Délai : {zone.delay}</div>
            </div>
            <div class="md:col-span-6 text-sm text-ink-700 dark:text-ink-200">
              {zone.price}
            </div>
          </div>
        ))}
      </div>

      <div class="mt-12 p-8 bg-volt-50 dark:bg-volt-900/20 border border-volt-200 dark:border-volt-700 rounded-2xl">
        <h3 class="font-display text-2xl font-medium mb-3">Livraison offerte pour les 15 premières commandes</h3>
        <p class="text-ink-700 dark:text-ink-200 mb-4">
          Profite de la livraison offerte à Dakar et banlieue en étant parmi les 15 premiers clients. Une fois le cap atteint, les frais standard s'appliqueront.
        </p>
        <a href={`https://wa.me/${SITE.whatsapp.number}`} target="_blank" rel="noopener noreferrer" class="btn-whatsapp">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.84 12.84 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.464 3.488"/>
          </svg>
          Commander sur WhatsApp
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
