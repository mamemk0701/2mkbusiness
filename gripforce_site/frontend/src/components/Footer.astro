---
import { SITE } from '../config.js';
const year = new Date().getFullYear();
---

<footer class="relative z-10 border-t border-ink-200 dark:border-ink-700 mt-20 md:mt-32">
  <div class="container-edge py-12 md:py-16">
    <!-- Top -->
    <div class="grid md:grid-cols-4 gap-10 md:gap-16">
      <div class="md:col-span-2">
        <div class="flex items-center gap-2.5 mb-4">
          <svg viewBox="0 0 40 40" class="w-8 h-8" aria-hidden="true">
            <circle cx="20" cy="20" r="7" fill="currentColor" class="text-ink-900 dark:text-ink-50" />
            <circle cx="20" cy="6" r="2.5" fill="currentColor" class="text-ink-900 dark:text-ink-50" />
            <circle cx="32" cy="13" r="2.5" fill="currentColor" class="text-ink-900 dark:text-ink-50" />
            <circle cx="32" cy="27" r="2.5" fill="currentColor" class="text-ink-900 dark:text-ink-50" />
            <circle cx="20" cy="34" r="2.5" fill="currentColor" class="text-ink-900 dark:text-ink-50" />
            <circle cx="8" cy="27" r="2.5" fill="currentColor" class="text-ink-900 dark:text-ink-50" />
            <circle cx="8" cy="13" r="2.5" fill="currentColor" class="text-ink-900 dark:text-ink-50" />
          </svg>
          <span class="font-display font-bold text-2xl tracking-tight">GripForce</span>
        </div>
        <p class="text-sm text-ink-600 dark:text-ink-300 max-w-sm leading-relaxed">
          {SITE.description}
        </p>
        <div class="flex gap-3 mt-6">
          <a href={SITE.social.tiktok} target="_blank" rel="noopener noreferrer" aria-label="TikTok" class="w-10 h-10 rounded-full border border-ink-200 dark:border-ink-700 hover:border-ink-400 dark:hover:border-ink-500 transition-colors flex items-center justify-center">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-5.2 1.74 2.89 2.89 0 012.31-4.64 2.93 2.93 0 01.88.13V9.4a6.84 6.84 0 00-1-.05A6.33 6.33 0 005.8 20.1a6.34 6.34 0 0010.86-4.43v-7a8.16 8.16 0 004.77 1.52v-3.4a4.85 4.85 0 01-1.84-0z"/>
            </svg>
          </a>
          <a href={SITE.social.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="w-10 h-10 rounded-full border border-ink-200 dark:border-ink-700 hover:border-ink-400 dark:hover:border-ink-500 transition-colors flex items-center justify-center">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
          </a>
          <a href={SITE.social.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="w-10 h-10 rounded-full border border-ink-200 dark:border-ink-700 hover:border-ink-400 dark:hover:border-ink-500 transition-colors flex items-center justify-center">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
        </div>
      </div>

      <div>
        <h4 class="label-eyebrow mb-4">Navigation</h4>
        <ul class="space-y-3">
          <li><a href="/#produit" class="text-sm text-ink-700 dark:text-ink-200 hover:text-ink-900 dark:hover:text-ink-50 transition-colors">Produit</a></li>
          <li><a href="/#benefices" class="text-sm text-ink-700 dark:text-ink-200 hover:text-ink-900 dark:hover:text-ink-50 transition-colors">Bénéfices</a></li>
          <li><a href="/#faq" class="text-sm text-ink-700 dark:text-ink-200 hover:text-ink-900 dark:hover:text-ink-50 transition-colors">FAQ</a></li>
          <li><a href="/cgv" class="text-sm text-ink-700 dark:text-ink-200 hover:text-ink-900 dark:hover:text-ink-50 transition-colors">CGV</a></li>
          <li><a href="/livraison" class="text-sm text-ink-700 dark:text-ink-200 hover:text-ink-900 dark:hover:text-ink-50 transition-colors">Livraison</a></li>
        </ul>
      </div>

      <div>
        <h4 class="label-eyebrow mb-4">Contact</h4>
        <ul class="space-y-3 text-sm text-ink-700 dark:text-ink-200">
          <li>
            <a href={`https://wa.me/${SITE.whatsapp.number}`} target="_blank" rel="noopener noreferrer" class="hover:text-success transition-colors">
              WhatsApp : {SITE.whatsapp.displayNumber}
            </a>
          </li>
          <li>Dakar · Sénégal</li>
          <li>Livraison 24h Dakar & banlieue</li>
        </ul>
      </div>
    </div>

    <!-- Bottom -->
    <div class="mt-12 pt-6 border-t border-ink-200 dark:border-ink-700 flex flex-col md:flex-row items-start md:items-center justify-between gap-3">
      <p class="text-xs text-ink-500 dark:text-ink-400">
        © {year} GripForce. Une marque de {SITE.brand}. Tous droits réservés.
      </p>
      <p class="text-[10px] font-mono uppercase tracking-[0.15em] text-ink-400 dark:text-ink-500">
        Made with ♥ in Dakar
      </p>
    </div>
  </div>
</footer>
