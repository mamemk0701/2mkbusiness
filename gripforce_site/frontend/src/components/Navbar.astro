---
import { SITE } from '../config.js';
import ThemeToggle from './ThemeToggle.jsx';
import CartButton from './CartButton.jsx';
---

<header
  class="sticky top-0 z-50 glass border-b border-ink-200/60 dark:border-ink-700/60"
>
  <div class="container-edge flex items-center justify-between h-16 md:h-20">
    <!-- Logo -->
    <a href="/" class="group flex items-center gap-2.5" aria-label="GripForce - Accueil">
      <div class="relative w-9 h-9 md:w-10 md:h-10">
        <svg viewBox="0 0 40 40" class="w-full h-full" aria-hidden="true">
          <!-- Stylisé : sphère centrale avec 6 branches -->
          <circle cx="20" cy="20" r="7" fill="currentColor" class="text-ink-900 dark:text-ink-50" />
          <circle cx="20" cy="6" r="2.5" fill="currentColor" class="text-ink-900 dark:text-ink-50" />
          <circle cx="32" cy="13" r="2.5" fill="currentColor" class="text-ink-900 dark:text-ink-50" />
          <circle cx="32" cy="27" r="2.5" fill="currentColor" class="text-ink-900 dark:text-ink-50" />
          <circle cx="20" cy="34" r="2.5" fill="currentColor" class="text-ink-900 dark:text-ink-50" />
          <circle cx="8" cy="27" r="2.5" fill="currentColor" class="text-ink-900 dark:text-ink-50" />
          <circle cx="8" cy="13" r="2.5" fill="currentColor" class="text-ink-900 dark:text-ink-50" />
          <line x1="20" y1="13" x2="20" y2="8" stroke="currentColor" stroke-width="1.5" class="text-ink-900 dark:text-ink-50" />
          <line x1="25.5" y1="16" x2="30" y2="14" stroke="currentColor" stroke-width="1.5" class="text-ink-900 dark:text-ink-50" />
          <line x1="25.5" y1="24" x2="30" y2="26" stroke="currentColor" stroke-width="1.5" class="text-ink-900 dark:text-ink-50" />
          <line x1="20" y1="27" x2="20" y2="32" stroke="currentColor" stroke-width="1.5" class="text-ink-900 dark:text-ink-50" />
          <line x1="14.5" y1="24" x2="10" y2="26" stroke="currentColor" stroke-width="1.5" class="text-ink-900 dark:text-ink-50" />
          <line x1="14.5" y1="16" x2="10" y2="14" stroke="currentColor" stroke-width="1.5" class="text-ink-900 dark:text-ink-50" />
        </svg>
      </div>
      <div class="flex flex-col leading-none">
        <span class="font-display font-bold text-lg md:text-xl tracking-tight">
          GripForce
        </span>
        <span class="hidden md:block text-[10px] font-mono uppercase tracking-[0.15em] text-ink-500 dark:text-ink-400 mt-0.5">
          by 2MK Business
        </span>
      </div>
    </a>

    <!-- Nav links (desktop) -->
    <nav class="hidden md:flex items-center gap-8">
      <a href="/#produit" class="text-sm font-medium text-ink-700 dark:text-ink-200 hover:text-ink-900 dark:hover:text-ink-50 transition-colors">
        Produit
      </a>
      <a href="/#benefices" class="text-sm font-medium text-ink-700 dark:text-ink-200 hover:text-ink-900 dark:hover:text-ink-50 transition-colors">
        Bénéfices
      </a>
      <a href="/#faq" class="text-sm font-medium text-ink-700 dark:text-ink-200 hover:text-ink-900 dark:hover:text-ink-50 transition-colors">
        FAQ
      </a>
    </nav>

    <!-- Actions -->
    <div class="flex items-center gap-1.5 md:gap-2">
      <ThemeToggle client:load />
      <CartButton client:load />
    </div>
  </div>
</header>
