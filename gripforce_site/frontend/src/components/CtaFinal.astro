---
import { PRODUCTS, LAUNCH_OFFER, SITE } from '../config.js';

const product = PRODUCTS[0];
const price = LAUNCH_OFFER.active ? product.priceLaunch : product.priceNormal;

const waMessage = encodeURIComponent(
  `Bonjour, j'aimerais commander un GripForce ${product.color} à ${price.toLocaleString('fr-FR')} FCFA.`
);
const waUrl = `https://wa.me/${SITE.whatsapp.number}?text=${waMessage}`;
---

<section id="contact" class="relative py-20 md:py-32 overflow-hidden">
  <div class="container-edge">
    <div class="relative rounded-3xl bg-ink-900 dark:bg-ink-800 text-ink-50 p-8 md:p-16 lg:p-24 overflow-hidden reveal">
      <!-- Decorative grid -->
      <div class="absolute inset-0 bg-grid-dark opacity-30" aria-hidden="true"></div>

      <!-- Decorative blur -->
      <div class="absolute -top-20 -right-20 w-96 h-96 bg-volt-500/20 rounded-full blur-3xl" aria-hidden="true"></div>

      <div class="relative grid md:grid-cols-2 gap-10 md:gap-16 items-center">
        <div>
          <div class="font-mono text-[11px] uppercase tracking-[0.2em] text-volt-400 mb-4">
            Prêt à commencer ?
          </div>
          <h2 class="h-display text-display-lg mb-6">
            Ta <span class="italic font-normal">poigne</span><br />
            a rendez-vous<br />
            avec <span class="italic font-normal text-volt-400">demain.</span>
          </h2>
          <p class="text-base md:text-lg text-ink-200 leading-relaxed max-w-md">
            Commande en 1 minute. Livraison à Dakar en 24h. Paiement Wave ou Orange Money.
          </p>
        </div>

        <div class="space-y-5">
          <!-- Prix card -->
          <div class="p-6 md:p-8 bg-ink-800 dark:bg-ink-900 border border-ink-700 rounded-2xl">
            <div class="flex items-baseline justify-between mb-1">
              <span class="text-sm text-ink-400">Prix de lancement</span>
              {LAUNCH_OFFER.active && product.priceOld && (
                <span class="text-sm text-ink-500 line-through tabular-nums">
                  {product.priceOld.toLocaleString('fr-FR')} F
                </span>
              )}
            </div>
            <div class="flex items-baseline gap-3 mb-5">
              <span class="font-display text-5xl md:text-6xl font-medium tabular-nums">
                {price.toLocaleString('fr-FR')}
                <span class="text-xl text-ink-400 font-sans">F</span>
              </span>
            </div>
            <div class="flex items-center gap-2 text-xs text-volt-400 mb-6">
              <span class="w-1.5 h-1.5 rounded-full bg-volt-400 animate-pulse-slow"></span>
              Livraison offerte à Dakar
            </div>
            <a href={waUrl} target="_blank" rel="noopener noreferrer" class="btn-whatsapp w-full">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.84 12.84 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.464 3.488"/>
              </svg>
              Commander maintenant
            </a>
          </div>

          <a href="#produit" class="block w-full text-center py-3 text-sm text-ink-400 hover:text-ink-50 transition-colors">
            Voir les détails du produit →
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
