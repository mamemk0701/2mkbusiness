---
import { FAQ } from '../config.js';
---

<section id="faq" class="relative py-20 md:py-32 bg-ink-100/40 dark:bg-ink-800/40 border-y border-ink-200 dark:border-ink-700">
  <div class="container-edge">
    <div class="grid md:grid-cols-12 gap-6 mb-12 md:mb-16 reveal">
      <div class="md:col-span-4">
        <div class="label-eyebrow mb-4">FAQ</div>
        <h2 class="h-display text-display-lg">
          Questions<br />
          <span class="italic font-normal">fréquentes.</span>
        </h2>
      </div>
      <div class="md:col-span-6 md:col-start-7 md:pt-4">
        <p class="text-base text-ink-700 dark:text-ink-200 leading-relaxed">
          Les réponses aux questions qu'on nous pose le plus. Tu ne trouves pas la tienne ?
          <a href="#contact" class="underline underline-offset-2 decoration-volt-500 decoration-2 hover:text-volt-500 transition-colors">
            Écris-nous sur WhatsApp
          </a>, on répond vite.
        </p>
      </div>
    </div>

    <div class="max-w-4xl mx-auto">
      {FAQ.map((item, i) => (
        <details
          class="group reveal border-t border-ink-200 dark:border-ink-700 last:border-b py-5 md:py-6"
          style={`transition-delay: ${i * 50}ms;`}
        >
          <summary class="flex items-start justify-between gap-6 cursor-pointer list-none">
            <div class="flex items-start gap-6">
              <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-ink-500 dark:text-ink-400 pt-1.5 hidden md:block">
                {String(i + 1).padStart(2, '0')}
              </span>
              <h3 class="font-display text-lg md:text-2xl font-medium pr-4">
                {item.q}
              </h3>
            </div>
            <div class="flex-shrink-0 w-8 h-8 md:w-10 md:h-10 rounded-full border border-ink-200 dark:border-ink-700 flex items-center justify-center group-open:rotate-45 transition-transform duration-300">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
                <path d="M12 5v14M5 12h14" />
              </svg>
            </div>
          </summary>
          <div class="pt-4 md:pt-5 md:pl-16 text-base text-ink-700 dark:text-ink-200 leading-relaxed max-w-2xl">
            {item.a}
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
